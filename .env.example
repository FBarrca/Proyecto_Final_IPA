# ===========================================
# Proyecto Final IPA - Variables de entorno
# ===========================================
# Copia como .env y rellena los valores reales.

# --- Groq (LLM para el agente) ---
GROQ_API_KEY=

# --- Azure OpenAI (Embeddings para RAG y tools médicos) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002

# --- Langfuse (Observabilidad y tracing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Ingestión de PDFs (opcional) ---
INGESTION_CHUNK_SIZE=1000
INGESTION_CHUNK_OVERLAP=200
